@article{mlp1,
author = {Zhang, Shiyuan and Huang, Da and Niu, Baojun and Bai, Ming},
title = {High-efficient optimisation method of antenna array radiation pattern synthesis based on multi-layer perceptron network},
journal = {IET Microwaves, Antennas \& Propagation},
volume = {16},
number = {12},
pages = {763-770},
doi = {https://doi.org/10.1049/mia2.12290},
url = {https://ietresearch.onlinelibrary.wiley.com/doi/abs/10.1049/mia2.12290},
eprint = {https://ietresearch.onlinelibrary.wiley.com/doi/pdf/10.1049/mia2.12290},
abstract = {Abstract With the increasing complexity of the application environment of antenna arrays and the increasing requirements for antenna array radiation patterns, efficient optimisation methods of antenna array radiation pattern synthesis have always been the challenges of the research. This paper proposes a method of utilising a multi-layer perceptron network to optimise the radiation patterns of antenna array. The optimisation requirements of the antenna array radiation pattern are described by defining the objective mask function, which is designed to shape the target radiation pattern by desired features. Simulation experiments have been designed with a variety of antenna array layouts, of which the radiation patterns with different requirements were successfully synthesised and optimised. The results show that the proposed method has high efficiency and satisfactory optimisation effect in dealing with the problem of complex radiation pattern requirements.},
year = {2022}
}

